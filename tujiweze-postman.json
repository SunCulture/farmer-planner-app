                  "const json = pm.response.json();",
                  "const maize = json.crops?.find(c => c.slug === 'maize');",
                  "const beans = json.crops?.find(c => c.slug === 'beans');",
                  "if (maize?.id) pm.environment.set('cropIdMaize', maize.id);",
                  "if (beans?.id) pm.environment.set('cropIdBeans', beans.id);"
                ],
                "type": "text/javascript"
