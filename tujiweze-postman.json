          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.environment.set('accessToken', json.data.accessToken);",
                  "}",
                  "if (json.data?.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  pm.environment.set('refreshToken', json.data.refreshToken);",
                  "}",
                  "if (json.data?.farmer?.id) {",
                  "  pm.collectionVariables.set('farmerId', json.data.farmer.id);",
                  "  pm.environment.set('farmerId', json.data.farmer.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.kamau@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Kamau\"\n}"
